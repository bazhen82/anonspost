# AnonsPost — скопируйте в .env и заполните

FLASK_SECRET_KEY=сгенерируйте-длинную-случайную-строку
ADMIN_LOGIN=admin
ADMIN_PASSWORD=смените-пароль

# Mail.ru SMTP
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=travel_assistent@mail.ru
SMTP_PASSWORD=пароль-приложения-mail-ru
SMTP_FROM=travel_assistent@mail.ru

# Куда слать тестовое письмо (можно тот же ящик)
TEST_EMAIL=travel_assistent@mail.ru

# Для ссылки «Отписаться» в письмах (на проде — ваш домен)
PUBLIC_BASE_URL=http://127.0.0.1:5000

MAX_EMAILS_PER_CAMPAIGN=50
MAIL_DELAY_SECONDS=1.0
